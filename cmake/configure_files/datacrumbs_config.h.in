#ifndef DATACRUMBS_CONFIG_HPP
#define DATACRUMBS_CONFIG_HPP
/* clang-format off */

/* Version string for Datacrumbs */
#define DATACRUMBS_PACKAGE_VERSION "@DATACRUMBS_PACKAGE_VERSION@"
#cmakedefine DATACRUMBS_GIT_VERSION "@DATACRUMBS_GIT_VERSION@"
#define DATACRUMBS_GET_VERSION(MAJOR, MINOR, PATCH) (MAJOR * 100000 + MINOR * 100 + PATCH)
#define DATACRUMBS_VERSION (DATACRUMBS_GET_VERSION @DATACRUMBS_VERSION@)
#define DATACRUMBS_VERSION_MAJOR (DATACRUMBS_VERSION / 100000)
#define DATACRUMBS_VERSION_MINOR ((DATACRUMBS_VERSION / 100) % 1000)
#define DATACRUMBS_VERSION_PATCH (DATACRUMBS_VERSION % 100)

/* Macro flags */
#cmakedefine DATACRUMBS_LOG_LEVEL @DATACRUMBS_LOG_LEVEL@
#cmakedefine DATACRUMBS_MODE @DATACRUMBS_MODE@
#cmakedefine DATACRUMBS_SRC_GEN_PATH "@DATACRUMBS_SRC_GEN_PATH@"
#cmakedefine LIBC_SO "@LIBC_SO@"
#cmakedefine DATACRUMBS_BUILD_CLIENT_SO "@DATACRUMBS_BUILD_CLIENT_SO@"

/* clang-format on */

#endif  // DATACRUMBS_CONFIG_HPP