version: @DATACRUMBS_RELEASE_VERSION_STRING@
lib_version: @DATACRUMBS_PACKAGE_VERSION@
install:
  prefix: @CMAKE_INSTALL_PREFIX@
  bin_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@
  sbin_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_SBINDIR@
  libexec_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_LIBEXEC_DIR@
  etc_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_SYSCONFDIR@
  configs_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_CONFIGS_DIR@
  data_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_DATA_DIR@
  modules_dir: ${DATACRUMBS_INSTALL_PREFIX}/@CMAKE_INSTALL_MODULES_DIR@
