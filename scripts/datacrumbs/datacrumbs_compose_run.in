#! /usr/bin/env bash

SCRIPT_DIR=@DATACRUMBS_INSTALL_BINARYDIR@

# Argument parsing
DATACRUMBS_USER=""
DATACRUMBS_COMPOSABLE_NAME=""
VERBOSE=0

show_help() {
    echo "Usage: $0 USER [COMPOSITE_NAME] [--verbose] [APP_CMD] [APP_ARGS...]"
    echo "  USER                  User to run as (required)"
    echo "  COMPOSITE_NAME        Composable name (optional, defaults to 'default')"
    echo "  --verbose             Enable verbose output"
    echo "  APP_CMD [APP_ARGS...] Command and arguments to run after server starts"
    echo "  -h, --help            Show this help message"
}

# Parse positional arguments
if [[ $# -lt 1 ]]; then
    log "Error: No user specified."
    show_help
    exit 1
fi

DATACRUMBS_USER="$1"
shift

# Check if next arg is composite name (not an option)
if [[ $# -gt 0 && "$1" != --* && "$1" != "-h" ]]; then
    DATACRUMBS_COMPOSABLE_NAME="$1"
    shift
else
    DATACRUMBS_COMPOSABLE_NAME="unknown"
fi

# Parse options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --verbose)
            VERBOSE=1
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        --*)
            log "Unknown option: $1"
            show_help
            exit 1
            ;;
        *)
            # First non-option is APP_CMD, break to leave $@ as app command
            break
            ;;
    esac
done

if [ -z "$DATACRUMBS_USER" ]; then
    log "Error: No user specified."
    show_help
    exit 1
fi


export DATACRUMBS_USER="$DATACRUMBS_USER"

source $SCRIPT_DIR/datacrumbs_setup $DATACRUMBS_USER

log "Running cmd: $@ as USER = $DATACRUMBS_USER and storing logs in $DATACRUMBS_LOG_PATH using composable $DATACRUMBS_COMPOSABLE_NAME"
debug "Script dir: $SCRIPT_DIR"
debug "User: $DATACRUMBS_USER"
debug "Composable name: $DATACRUMBS_COMPOSABLE_NAME"
debug "Dry run: $DRY_RUN"
debug "Verbose: $VERBOSE"

datacrumbs_init $DATACRUMBS_USER $DATACRUMBS_LOG_PATH
RUNID=$(date +"%Y%m%d_%H%M%S")
DATACRUMBS_LOG_FILE=$PWD/datacrumbs_${DATACRUMBS_USER}_${RUNID}.log
exec=${DATACRUMBS_CLIENT_BIN}/datacrumbs_${DATACRUMBS_COMPOSABLE_NAME}

datacrumbs_start_server $exec

log "Running App: $@"
"$@"
log "Finished App: $@"

datacrumbs_stop_server $exec

datacrumbs_print_status

datacrumbs_finalize $DATACRUMBS_USER $DATACRUMBS_LOG_PATH
debug "Finalized datacrumbs for user $DATACRUMBS_USER"
