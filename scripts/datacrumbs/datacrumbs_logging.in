#! /usr/bin/env bash

log() {
  if [ "${QUIET:-0}" -eq 0 ]; then
    printf "[INFO $(date '+%Y-%m-%d %H:%M:%S')] $@"
    printf "\n"
  fi
}

debug() {
  if [ "${VERBOSE:-0}" -eq 1 ] && [ "${QUIET:-1}" -eq 0 ]; then
    printf "[DEBUG $(date '+%Y-%m-%d %H:%M:%S')] $@"
    printf "\n"
  fi
}

error() {
  if [ "${QUIET:-1}" != "" ] && [ "${QUIET:-1}" -eq 0 ]; then
    printf "[ERROR $(date '+%Y-%m-%d %H:%M:%S')] $@" >&2
    printf "\n" >&2
  fi
}

warn() {
  if [ "${QUIET:-1}" != "" ] && [ "${QUIET:-1}" -eq 0 ]; then
    printf "[WARN $(date '+%Y-%m-%d %H:%M:%S')] $@" >&2
    printf "\n" >&2
  fi
}
