#! /usr/bin/env bash

SCRIPT_DIR=@DATACRUMBS_INSTALL_BINARYDIR@

export DATACRUMBS_USER=$1

if [ -z "$DATACRUMBS_USER" ]; then
    echo "Error: DATACRUMBS_USER is not set. Please provide a user as the first argument."
    exit 1
fi

source $SCRIPT_DIR/datacrumbs_setup $DATACRUMBS_USER


shift


echo "Running cmd: $@ as USER = $DATACRUMBS_USER and storing traces in $DATACRUMBS_LOG_PATH and log file $DATACRUMBS_LOG_FILE"

datacrumbs_init $DATACRUMBS_USER $DATACRUMBS_LOG_PATH
RUNID=$(date +"%Y%m%d_%H%M%S")
DATACRUMBS_LOG_FILE=$PWD/datacrumbs_${DATACRUMBS_USER}_${RUNID}.log

datacrumbs_start_server @CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_SBINDIR@/datacrumbs

log "Running App: $@"
log  "$@"
"$@"
log "Finished App: $@"

datacrumbs_stop_server @CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_SBINDIR@/datacrumbs

datacrumbs_finalize $DATACRUMBS_USER $DATACRUMBS_LOG_PATH
