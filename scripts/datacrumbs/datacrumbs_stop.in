#! /usr/bin/env bash

set -eo pipefail

SCRIPT_DIR=@DATACRUMBS_INSTALL_BINARYDIR@

PROG_NAME=$1

# Load environment
source "$SCRIPT_DIR/datacrumbs_setup"

if [[ "$DATACRUMBS_IS_ROOT" != "1" ]]; then
	error "This script should be run as root."
	exit 1
fi

if [[ "$PROG_NAME" == "" ]]; then
	ps -aef | grep 'datacrumbs' | grep ${DATACRUMBS_USER} | awk '{print $2}' | xargs kill -9
else
	ps -aef | grep 'datacrumbs' | grep ${DATACRUMBS_USER} | grep -v $PROG_NAME | awk '{print $2}' | xargs kill -9
fi
