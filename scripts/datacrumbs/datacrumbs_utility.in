#! /usr/bin/env bash

SCRIPT_DIR=@DATACRUMBS_INSTALL_BINARYDIR@

# Load logging script
if [[ -f "$SCRIPT_DIR/datacrumbs_logging" ]]; then
    source "$SCRIPT_DIR/datacrumbs_logging"
else
    echo "Error: datacrumbs_logging not found in $SCRIPT_DIR"
    exit 1
fi

function datacrumbs_parse_yaml {
    local prefix=$2
    local s='[[:space:]]*' w='[a-zA-Z0-9_]*' fs=$(echo @ | tr @ '\034')
    sed -ne "s|^\($s\):|\1|" -e "s|^\($s\)\($w\)$s:$s[\"']\(.*\)[\"']$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)\($w\)$s:$s\(.*\)$s\$|\1$fs\2$fs\3|p" $1 |
        awk -F$fs '{
    indent = length($1)/2;
    vname[indent] = toupper($2);
    for (i in vname) {if (i > indent) {delete vname[i]}}
    if (length($3) > 0) {
       vn=""; for (i=0; i<indent; i++) {vn=(vn)(vname[i])("_")}
       printf("export %s%s%s=\"%s\";", "'$prefix'",vn, toupper($2), $3);
       printf("readonly %s%s%s;", "'$prefix'",vn, toupper($2));
    }
  }'
}

function datacrumbs_run_command() {
  local err_msg="$1"
  shift
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log "[DRY RUN] Would run: $*"
    return 0
  fi
  "$@"
  local status=$?
  if [ $status -ne 0 ]; then
    log "Error: $err_msg"
    exit $status
  fi
}

# Usage example:
# datacrumbs_run_command "Failed to list directory" ls /nonexistent/path

function datacrumbs_finalize() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log "[DRY RUN] Would finalize for user: $DATACRUMBS_USER, log path: $DATACRUMBS_LOG_PATH"
    return 0
  fi
}

function datacrumbs_init() {
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log "[DRY RUN] Would create log directory: ${DATACRUMBS_LOG_PATH}"
    return 0
  fi

  datacrumbs_run_command "Failed to create log directory ${DATACRUMBS_LOG_PATH}" mkdir -p "${DATACRUMBS_LOG_PATH}"
  
}

function datacrumbs_start_server() {
  exec=$1
  common_cmd=("$DATACRUMBS_INSTALL_HOST" "--user" "$DATACRUMBS_USER" "--config_path" "$DATACRUMBS_INSTALL_CONFIGS_DIR" "--data_dir" "$DATACRUMBS_INSTALL_DATA_DIR" "--trace_log_dir" "$DATACRUMBS_LOG_PATH" --run_id "$RUNID")
  cmd=("$exec" "run" "${common_cmd[@]}")
  READY_FILE="/tmp/datacrumbs_${DATACRUMBS_USER}_${RUNID}.ready"
  TIMEOUT=600  # 10 minutes in seconds
  WAIT_INTERVAL=2
  ELAPSED=0

  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log "[DRY RUN] Would start server: ${cmd[@]}"
    log "[DRY RUN] Would wait for ready file: $READY_FILE (timeout: $TIMEOUT seconds)"
    return 0
  fi

  log "Starting Server: ${cmd[@]}"
  sudo "${cmd[@]}" > $DATACRUMBS_LOG_FILE 2>&1 &

  while [ ! -f "$READY_FILE" ]; do
      sleep $WAIT_INTERVAL
      log "Waiting for $Server..."
      ELAPSED=$((ELAPSED + WAIT_INTERVAL))
      if [ $ELAPSED -ge $TIMEOUT ]; then
          log "Timeout waiting for $READY_FILE"
          SERVER_PID=$(ps aux | grep "${RUNID}" | grep -v grep | awk '{print $2}')
          if [ -n "$SERVER_PID" ]; then
              sudo kill -9 $SERVER_PID
          fi
          exit 1
      fi
  done

  log "Started server"
}

function datacrumbs_stop_server() {
  exec=$1
  cmd=("$exec" "stop" "${common_cmd[@]}")
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log "[DRY RUN] Would stop server: ${cmd[@]}"
    log "[DRY RUN] Would find and kill process(es) with RUNID ${RUNID}"
    log "[DRY RUN] Would remove ready file: $READY_FILE"
    return 0
  fi

  log "Stopping Server: ${cmd[@]}"
  sudo "${cmd[@]}" >> $DATACRUMBS_LOG_FILE 2>&1

  SERVER_PID=$(ps aux | grep "${RUNID}" | grep -v grep | awk '{print $2}')
  if [ -n "$SERVER_PID" ]; then
      log "Found process(es) with RUNID ${RUNID}: $SERVER_PID. Killing them."
      sudo kill -9 $SERVER_PID
  fi
  sudo rm -f $READY_FILE
  log "Stopped server"
}

function datacrumbs_print_status() {
  local status_file="/tmp/datacrumbs_${DATACRUMBS_USER}_status_${RUNID}.json"
  if [ "${DRY_RUN:-0}" -eq 1 ]; then
    log "[DRY RUN] Would print status from: $status_file"
    log "[DRY RUN] Would remove status file: $status_file"
    return 0
  fi

  if [ ! -f "$status_file" ]; then
    log "Status file not found: $status_file"
    return 1
  fi

  local trace_file total_events_captured events_failed
  trace_file=$(jq -r '.trace_file' "$status_file")
  total_events_captured=$(jq -r '.total_events_captured' "$status_file")
  events_failed=$(jq -r '.events_failed' "$status_file")

  log "trace_file: $trace_file"
  log "total_events_captured: $total_events_captured"
  log "events_failed: $events_failed"
  rm -f "$status_file"
}



if command -v module &> /dev/null
then
   export DATACRUMBS_MODULE_AVAILABLE=1
else
   export DATACRUMBS_MODULE_AVAILABLE=0
fi